# Copy to .env and fill in real values. Never commit .env.

# Anthropic — for intent classifier (Haiku) + answer composer (Sonnet)
ANTHROPIC_API_KEY=

# NREL PVWatts v8 — annual production estimate by lat/lon + system params
# Sign up: https://developer.nrel.gov/signup
NREL_API_KEY=

# EIA — state electricity prices (used in payback calculation)
# Sign up: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# DSIRE — public, no key needed. Override only to mock during dev.
DSIRE_BASE_URL=https://programs.dsireusa.org/api/v1

# Your own Solar Cost Explorer GraphQL endpoint
SOLAR_COST_GRAPHQL_URL=https://solar.danhle.net/graphql/

# Langfuse — agent run tracing (optional; agent runs without it)
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Server
LOG_LEVEL=INFO
